# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=development

# The public URL of this app (used in metadata, OG, PWA manifest)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Display name shown in the UI and browser tab
NEXT_PUBLIC_APP_NAME=App

# ============================================================
# DATABASE — MongoDB
# ============================================================
# Local dev:   mongodb://localhost:27017/appdb
# Atlas:       mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>
MONGODB_URI=mongodb://localhost:27017/appdb

# ============================================================
# SECURITY
# ============================================================
# Must be at least 32 characters. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=replace-with-a-secret-of-at-least-32-characters
